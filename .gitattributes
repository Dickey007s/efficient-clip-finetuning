# Normalize line endings across platforms
* text=auto eol=lf

# Explicit text files
*.md       text eol=lf
*.py       text eol=lf
*.txt      text eol=lf
*.csv      text eol=lf
*.tex      text eol=lf
*.bib      text eol=lf
*.yml      text eol=lf
*.yaml     text eol=lf
*.json     text eol=lf
*.sh       text eol=lf
*.bat      text eol=crlf
*.cmd      text eol=crlf

# Binary files
*.png      binary
*.jpg      binary
*.jpeg     binary
*.pdf      binary
*.ipynb    binary
